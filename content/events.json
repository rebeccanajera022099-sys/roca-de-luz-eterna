- name: "events"
  label: "Eventos"
  folder: "content/events"
  create: true
  slug: "{{year}}-{{month}}-{{day}}-{{slug}}"
  extension: "json"
  format: "json"
  fields:
    - { label: "Fecha", name: "date", widget: "datetime", format: "YYYY-MM-DD", time_format: false }
    - { label: "Título (ES)", name: "title_es", widget: "string" }
    - { label: "Title (EN)", name: "title_en", widget: "string" }
    - { label: "Lugar (ES)", name: "where_es", widget: "string" }
    - { label: "Location (EN)", name: "where_en", widget: "string" }
